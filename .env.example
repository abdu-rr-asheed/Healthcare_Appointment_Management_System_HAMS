# ============================================================
# HAMS - Healthcare Appointment Management System
# Environment Variables Template
# ============================================================
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Replace placeholder values with actual values
# 3. Never commit .env file to version control
# 4. Keep .env.example for reference only
# ============================================================

# ============================================================
# Frontend Configuration
# ============================================================
SENTRY_DSN=your-sentry-dsn-here
ENVIRONMENT=production

# ============================================================
# Backend - ASP.NET Core
# ============================================================
ASPNETCORE_ENVIRONMENT=production
LOG_LEVEL=Information

# ============================================================
# Backend - Database (PostgreSQL)
# ============================================================
DB_PASSWORD=your-secure-postgresql-password-here
# Note: Connection string is automatically constructed in docker-compose.yml
# Format: Host=db;Port=5432;Database=HAMS;Username=postgres;Password=${DB_PASSWORD}

# ============================================================
# Backend - JWT Authentication
# ============================================================
# Generate a secure 256-bit key: openssl rand -base64 32
JWT_SECRET_KEY=your-256-bit-secret-key-here
JWT_ISSUER=HAMS
JWT_AUDIENCE=HAMS-Patients

# ============================================================
# Backend - EHR Integration
# ============================================================
EHR_FHIR_URL=https://ehr.hospital.nhs.uk/fhir
EHR_AUTH_TOKEN=your-oauth-bearer-token-here

# ============================================================
# Backend - Email Notifications
# ============================================================
SMTP_HOST=smtp.hospital.nhs.uk
SMTP_PORT=587
SMTP_USER=your-smtp-username-here
SMTP_PASSWORD=your-smtp-password-here
SMTP_USE_SSL=true
FROM_EMAIL=noreply@hams.hospital.nhs.uk

# ============================================================
# Backend - SMS Notifications
# ============================================================
SMS_API_URL=https://sms-provider.example.com/api/v1
SMS_API_KEY=your-sms-api-key-here
SMS_SENDER_ID=HAMS

# ============================================================
# Additional Configuration (Optional)
# ============================================================
# Backup configuration
BACKUP_RETENTION_DAYS=90
BACKUP_SCHEDULE=0 2 * * *

# Session configuration
SESSION_TIMEOUT_CLINICIAN=30
SESSION_TIMEOUT_PATIENT=60

# Feature flags
FEATURE_SLOT_SUGGESTIONS=true
FEATURE_EHR_WRITE_BACK=false
FEATURE_SMS_REMINDERS=true

# Rate limiting
RATE_LIMIT_API_REQUESTS_PER_SECOND=10
RATE_LIMIT_LOGIN_ATTEMPTS_PER_MINUTE=5

# CORS configuration (if needed)
CORS_ALLOWED_ORIGINS=https://hams.hospital.nhs.uk
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization

# ============================================================
# Docker Configuration (Optional)
# ============================================================
# Resource limits
DOCKER_MEMORY_LIMIT_BACKEND=2048
DOCKER_MEMORY_LIMIT_FRONTEND=512
DOCKER_MEMORY_LIMIT_DB=2048
DOCKER_MEMORY_LIMIT_REDIS=512

# Timezone
TZ=Europe/London
